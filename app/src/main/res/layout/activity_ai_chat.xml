<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal">

    <com.example.cropcart.gui.text.SimpleTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Chat"
        android:textAlignment="center"
        android:background="@color/primary_lighter"
        app:preset="activity_name"
        />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/background_darker"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAIChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/background_darker"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:background="@color/background_lighter"
        >

        <EditText
            android:id="@+id/aiCharInputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Chat with the AI"
            android:layout_weight="1"
            android:inputType="textMultiLine"
            android:minLines="1"
            android:maxLines="5"
            android:scrollbars="vertical"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:layout_margin="4dp"
            />

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            app:cardCornerRadius="100dp"
            app:cardBackgroundColor="@color/primary_lighter"
            app:cardElevation="4dp"
            >

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="@dimen/ai_chat_send_btn_size"
                android:layout_height="@dimen/ai_chat_send_btn_size"
                android:layout_margin="4dp"
                android:src="@drawable/baseline_send_24"
                android:backgroundTint="@android:color/transparent"
                android:tint="@color/background_lighter"
                android:padding="@dimen/ai_chat_icon_padding"
                />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>