<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:padding="16dp"
    android:fillViewport="true"
    android:background="#F8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Product"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111"
            android:layout_marginBottom="24dp" />

        <!-- Product Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product Name"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <RadioGroup
            android:id="@+id/radioCategoryGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All" />

            <RadioButton
                android:id="@+id/radioCereals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cereals" />

            <RadioButton
                android:id="@+id/radioPulses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pulses" />

            <RadioButton
                android:id="@+id/radioVegetables"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vegetables" />

            <RadioButton
                android:id="@+id/radioFruits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fruits" />

            <RadioButton
                android:id="@+id/radioOilSeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Oil Seeds" />

            <RadioButton
                android:id="@+id/radioSpices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Spices" />

            <RadioButton
                android:id="@+id/radioSeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seeds" />

            <RadioButton
                android:id="@+id/radioOthers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Others" />

        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantity"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Price -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Price"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Image URL -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Image URL"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Section"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioSectionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioFreshProduce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fresh Produce" />

            <RadioButton
                android:id="@+id/radioDried"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dried" />

            <RadioButton
                android:id="@+id/radioProcessed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Processed" />

            <RadioButton
                android:id="@+id/radioOrganic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organic" />

            <RadioButton
                android:id="@+id/radioNonOrganic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Non-organic" />

            <RadioButton
                android:id="@+id/radioHybridSeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hybrid Seeds" />

            <RadioButton
                android:id="@+id/radioRawMaterial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Raw Material" />

            <RadioButton
                android:id="@+id/radioAnimalFeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Animal Feed Quality" />

        </RadioGroup>
        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Product"
            android:textColor="@android:color/white"
            android:backgroundTint="#2d17d4"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"
            android:paddingVertical="12dp" />

    </LinearLayout>
</ScrollView>
