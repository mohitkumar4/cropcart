<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.cropcart.gui.text.SimpleTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="From MediaStack"
        android:textAlignment="center"
        app:preset="primary_text"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMediaStack"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"
        />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/background_darker"
        android:layout_marginVertical="8dp"
        />

    <com.example.cropcart.gui.text.SimpleTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="From Apitube"
        android:textAlignment="center"
        app:preset="primary_text"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApitube"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"
        />


</LinearLayout>