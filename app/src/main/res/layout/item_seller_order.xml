<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/rounded_product_section">

    <!-- Order info -->
    <TextView
        android:id="@+id/orderIdText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Order ID: #12345"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/orderTotalPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: ₹400"
        android:textColor="#4CAF50"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/orderStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Pending"
        android:textColor="#757575"
        android:layout_marginTop="4dp" />

    <!-- Buttons for updating status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnMarkShipped"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Mark as Shipped"
            android:textSize="12sp"
            android:backgroundTint="@color/blue_primary"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnMarkDelivered"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Delivered"
            android:textSize="12sp"
            android:backgroundTint="@color/green_button"
            android:textColor="@android:color/white" />
    </LinearLayout>

</LinearLayout>
