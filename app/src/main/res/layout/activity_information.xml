<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainInformationLayout"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:paddingVertical="@dimen/activityPaddingVertical"
    android:paddingHorizontal="@dimen/activityPaddingHorizontal"
    >

    <com.example.cropcart.gui.text.SimpleTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Information"
        android:textAlignment="center"
        app:preset="activity_name"
        />

    <FrameLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/background_darker"
        android:layout_marginVertical="8dp"
        />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        >

        <ImageButton
            android:id="@+id/btnNews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:src="@drawable/baseline_newspaper_24"
            android:backgroundTint="@color/background_lighter"
            app:tint="@color/background_darker"
            />

        <ImageButton
            android:id="@+id/btnWeather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:src="@drawable/baseline_wb_sunny_24"
            android:backgroundTint="@color/background_darker"
            app:tint="@color/background_lighter"
            />

    </LinearLayout>

</LinearLayout>