<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="#F8F8F8"
    tools:context=".product.ProductDetailActivity">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"> <!-- leave space for bottom bar -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Full-width product image -->
            <ImageView
                android:id="@+id/productImage"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scaleType="centerCrop"
                android:background="#EAEAEA"
                tools:src="@drawable/img" />

            <!-- Info below image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="@drawable/rounded_product_section"
                android:layout_margin="8dp">

                <TextView
                    android:id="@+id/productName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wheat (Premium Quality)"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#111" />

                <TextView
                    android:id="@+id/productPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 1200 / quintal"
                    android:textColor="@color/green_primary"
                    android:textSize="18sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/sellerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seller: Rajesh Farms"
                    android:textColor="#555"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/descriptionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/productDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This is high-quality wheat grown organically without pesticides."
                    android:textColor="#444"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Similar Products Section -->
            <!-- Similar Products Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="600dp"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:layout_margin="8dp"
                android:background="@drawable/rounded_product_section">

                <TextView
                    android:id="@+id/similarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Similar Products"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/similarRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>



        </LinearLayout>
    </ScrollView>

    <!-- Fixed Bottom Bar -->
    <!-- Fixed Bottom Bar -->
    <!-- Fixed Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- Price -->
        <TextView
            android:id="@+id/bottomPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="₹ 1200 / quintal"
            android:textSize="18sp"
            android:textColor="@color/green_primary"
            android:textStyle="bold" />

        <!-- Add to Cart Button (initially visible) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add to Cart"
            android:backgroundTint="@color/green_button"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp"/>

        <!-- Quantity Selector (initially gone) -->
        <LinearLayout
            android:id="@+id/quantityLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:background="@drawable/rounded_button"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <!-- Decrease -->
            <TextView
                android:id="@+id/btnDecrease"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@null" />

            <!-- Quantity -->
            <TextView
                android:id="@+id/quantityText"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="16sp"
                android:gravity="center"
                android:textColor="@android:color/white" />

            <!-- Increase -->
            <TextView
                android:id="@+id/btnIncrease"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@null" />
        </LinearLayout>

    </LinearLayout>


</FrameLayout>
